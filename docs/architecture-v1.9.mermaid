%%{init: {
  "theme": "base",
  "themeVariables": {
    "primaryColor": "#4F46E5",
    "primaryTextColor": "#ffffff",
    "primaryBorderColor": "#3730A3",
    "lineColor": "#6B7280",
    "secondaryColor": "#EEF2FF",
    "tertiaryColor": "#F9FAFB",
    "background": "#ffffff",
    "fontSize": "14px"
  }
}}%%

flowchart TB

  %% ── USER ────────────────────────────────────────────────────────────────
  USER(["👤 User\n(Browser)"])

  %% ── FRONTEND ─────────────────────────────────────────────────────────────
  subgraph FE["🖥️  Frontend — React 18 + Vite + React Router v6"]
    direction LR

    subgraph Pages["Pages"]
      P1["📊 Dashboard\nSummary · Trend · YoY\nPrediction · Goals · Insights"]
      P2["💸 Expenses\nCRUD · Bulk Delete · CSV Export"]
      P3["🎯 Budgets\nSet · Status Bars · Period Filter"]
      P4["🏷️ Categories\nRich Emoji Picker · Color Presets"]
      P5["💬 Chat\nAI Q&A · Inline Charts"]
      P6["🔄 Recurring\nTemplates · Auto-Generate"]
      P7["🔔 Alerts\nThreshold · Category Spike · Read"]
      P8["🏆 Goals\nProgress Bars · Deadline Tracking"]
    end

    subgraph FEInfra["Infrastructure"]
      CTX["PeriodContext\nWeek/Month/Quarter/Year"]
      HOOK1["useAutoRefresh\n30s tick"]
      HOOK2["useChartTheme\nDark/Light colours"]
      SPLASH["SplashScreen\nv1.9.0"]
    end
  end

  %% ── VERSION TIMELINE ─────────────────────────────────────────────────────
  subgraph VER["📋  Version Timeline"]
    direction LR
    V1["v1.0\nCore CRUD\nExpenses+Categories"]
    V2["v1.1–v1.2\nIncome type\nPeriod filter"]
    V3["v1.3\nDrill-down\nPie+Bar charts"]
    V4["v1.4\nMobile UI\nAuto-refresh"]
    V5["v1.5\nChat AI\nBulk ops · CSV export"]
    V6["v1.6\nDark mode\nCollapsible sidebar"]
    V7["v1.7\nRecurring · Alerts\nGoals tracker"]
    V8["v1.8\nYoY chart\nSpend prediction\n3 new insight rules"]
    V9["v1.9\nRich emoji picker\nVersion badge fix"]
    V1 --> V2 --> V3 --> V4 --> V5 --> V6 --> V7 --> V8 --> V9
  end

  %% ── BACKEND ──────────────────────────────────────────────────────────────
  subgraph BE["⚡  Backend — FastAPI 0.111 + SQLModel 0.0.18 + Pydantic v2"]
    direction TB

    subgraph Routers["API Routers  (prefix: /api/v1)"]
      direction LR
      R1["/expenses\nCRUD + bulk-delete\nauto-categorise"]
      R2["/reports\nmonthly-summary · by-category\ntrend · yoy · prediction\ntop-expenses"]
      R3["/budgets\nCRUD · status · bulk-delete"]
      R4["/categories\nCRUD"]
      R5["/insights\n10 rule-based checks"]
      R6["/chat\nLLM Q&A"]
      R7["/recurring-expenses\nCRUD · generate · generate-all"]
      R8["/alerts\ngenerate · read · bulk-read"]
      R9["/goals\nCRUD"]
    end

    subgraph Services["Services"]
      direction LR
      S1["report_service\nget_monthly_summary\nget_year_over_year\nget_spend_prediction\nget_spend_trend\nget_top_expenses"]
      S2["insights_service\n10 Rules:\n1.budget_overspend  2.burn_rate\n3.mom_spike          4.top_category\n5.unusual_expense    6.savings_opportunity\n7.streak             8.daily_rate\n9.savings_rate       10.yoy_comparison"]
      S3["chat_service\nNatural language Q&A\nAuto-categorise\nInline chart generation"]
    end

    subgraph Middleware["Middleware"]
      MW["RequestValidationError handler\n422 logging · jsonable_encoder"]
    end

    Routers --> Services
    Middleware -.-> Routers
  end

  %% ── DATABASE ─────────────────────────────────────────────────────────────
  subgraph DB["🗄️  PostgreSQL 15  (Docker volume: postgres_data)"]
    direction LR
    T1["expenses\namount · date · description\nnotes · type · category_id"]
    T2["categories\nname · emoji · color\ncategory_type · is_default"]
    T3["budgets\namount · month · year\ncategory_id"]
    T4["recurring_expenses\nfrequency · next_date\nis_active · category_id"]
    T5["spending_alerts\ntype · severity · message\nis_read · month · year"]
    T6["goals\nname · target_amount\ncurrent_amount · deadline\nis_completed"]
  end

  %% ── EXTERNAL ─────────────────────────────────────────────────────────────
  LLM(["🤖 LLM\nOpenAI / Anthropic\nAuto-categorise · Chat"])

  %% ── CONNECTIONS ──────────────────────────────────────────────────────────
  USER -->|"HTTP/HTTPS"| FE
  FE -->|"Axios REST\nJSON"| BE
  BE -->|"SQLModel ORM\nSQL queries"| DB
  BE -->|"API calls"| LLM
  S3 <-->|"Completions API"| LLM

  %% ── DOCKER COMPOSE ───────────────────────────────────────────────────────
  subgraph Docker["🐳  Docker Compose"]
    direction LR
    DC1["backend\n:8000\nFastAPI + Uvicorn"]
    DC2["frontend\n:5173\nVite dev server"]
    DC3["db\n:5432\nPostgreSQL 15"]
    DC1 <--> DC3
  end

  %% ── STYLES ───────────────────────────────────────────────────────────────
  classDef page fill:#4F46E5,stroke:#3730A3,color:#fff,rx:8
  classDef service fill:#059669,stroke:#047857,color:#fff,rx:8
  classDef router fill:#0891B2,stroke:#0E7490,color:#fff,rx:8
  classDef db fill:#D97706,stroke:#B45309,color:#fff,rx:8
  classDef ver fill:#7C3AED,stroke:#6D28D9,color:#fff,rx:6
  classDef external fill:#EC4899,stroke:#DB2777,color:#fff,rx:8

  class P1,P2,P3,P4,P5,P6,P7,P8 page
  class S1,S2,S3 service
  class R1,R2,R3,R4,R5,R6,R7,R8,R9 router
  class T1,T2,T3,T4,T5,T6 db
  class V1,V2,V3,V4,V5,V6,V7,V8,V9 ver
  class LLM external
