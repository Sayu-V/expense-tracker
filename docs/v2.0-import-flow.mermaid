%%{init: {
  "theme": "base",
  "themeVariables": {
    "primaryColor": "#4F46E5",
    "primaryTextColor": "#ffffff",
    "primaryBorderColor": "#3730A3",
    "lineColor": "#6B7280",
    "secondaryColor": "#EEF2FF",
    "tertiaryColor": "#F0FDF4",
    "background": "#ffffff",
    "fontSize": "14px"
  }
}}%%

flowchart TD

  %% ── ENTRY POINT ───────────────────────────────────────────────────────────
  START(["👤 User visits\n📥 Import Page"])
  START --> UPLOAD

  UPLOAD["📂 Drag-and-drop or\nClick to Upload\nCSV or PDF file"]
  UPLOAD --> FILETYPE

  %% ── FILE TYPE DETECTION ──────────────────────────────────────────────────
  FILETYPE{{"❓ File type?"}}
  FILETYPE -->|".csv"| CSV_PARSE
  FILETYPE -->|".pdf"| PDF_EXTRACT

  %% ── PDF PATH ─────────────────────────────────────────────────────────────
  PDF_EXTRACT["📄 pdfplumber\nExtract tables from PDF pages\n(handles HDFC, SBI, ICICI, Axis PDFs)"]
  PDF_EXTRACT --> PDF_OK{{"Tables\nfound?"}}
  PDF_OK -->|"Yes"| CSV_PARSE
  PDF_OK -->|"No — scanned/image PDF"| PDF_ERR

  PDF_ERR["⚠️ Error returned to user:\nScanned PDF detected.\nPlease download CSV\nversion from your bank app."]
  PDF_ERR --> UPLOAD

  %% ── CSV PARSE ────────────────────────────────────────────────────────────
  CSV_PARSE["🔍 Read raw CSV rows\n(Python csv module)"]
  CSV_PARSE --> DETECT

  %% ── BANK DETECTION ───────────────────────────────────────────────────────
  DETECT{{"🏦 Detect bank format\nby inspecting headers"}}

  DETECT -->|"Narration + Withdrawal Amt\n+ Deposit Amt"| HDFC_S
  DETECT -->|"Narration + Debit + Credit\n(credit card header)"| HDFC_CC
  DETECT -->|"Description + Txn Date\n+ Debit + Credit"| SBI
  DETECT -->|"Transaction Remarks\n+ Withdrawal Amount"| ICICI
  DETECT -->|"PARTICULARS + DR + CR\n+ Tran Date"| AXIS
  DETECT -->|"No match — attempt\nfuzzy column detection"| GENERIC

  %% ── BANK-SPECIFIC PARSERS ────────────────────────────────────────────────
  HDFC_S["🏦 HDFC Savings Parser\nDate: DD/MM/YY\nDebit ← Withdrawal Amt\nCredit ← Deposit Amt\nDesc ← Narration"]
  HDFC_CC["💳 HDFC Credit Card Parser\nDate: DD/MM/YYYY\nDebit ← Debit col\nCredit ← Credit col\nDesc ← Narration"]
  SBI["🏦 SBI Parser\nDate: DD MMM YYYY\nDebit ← Debit col\nCredit ← Credit col\nDesc ← Description"]
  ICICI["🏦 ICICI Parser\nDate: DD/MM/YYYY\nDebit ← Withdrawal Amount\nCredit ← Deposit Amount\nDesc ← Transaction Remarks"]
  AXIS["🏦 Axis Parser\nDate: DD-MM-YYYY\nDebit ← DR col\nCredit ← CR col\nDesc ← PARTICULARS"]
  GENERIC["⚙️ Generic CSV Fallback\nFuzzy-match column names:\ndate / amount / description\nFlags ambiguous rows for user review"]

  %% ── NORMALISE ────────────────────────────────────────────────────────────
  HDFC_S & HDFC_CC & SBI & ICICI & AXIS & GENERIC --> NORMALISE

  NORMALISE["✅ Normalised Rows\nEach row: date · description · amount · type\nSkip: zero-amount · duplicate-ref rows\nSkip: opening/closing balance rows"]

  %% ── AI CATEGORISATION ────────────────────────────────────────────────────
  NORMALISE --> AI_CAT

  AI_CAT["🤖 AI Auto-Categorise\n(Reuses existing LLM service)\nFor each row:\n  → Pass description + your category list\n  → LLM picks best-matching category\n  → Returns category_id + confidence\nFallback: Uncategorized if no match"]

  AI_CAT --> PREVIEW_BUILD

  %% ── PREVIEW ──────────────────────────────────────────────────────────────
  PREVIEW_BUILD["📋 Build ImportPreview response\n{ bank, format, total_rows, rows[] }"]
  PREVIEW_BUILD --> PREVIEW_UI

  PREVIEW_UI["🖥️ Preview Table shown to user\n┌─────────────────────────────────────────────┐\n│ ☑  Date       Description   Amount  Category  │\n│ ☑  28/03/26   Swiggy Food   ₹450    🍔 Food   │\n│ ☑  27/03/26   Uber Ride     ₹180    🚗 Travel │\n│ ☐  26/03/26   ATM Withdraw  ₹5000   (skip)    │\n│ ☑  25/03/26   Amazon.in     ₹1299   🛒 Shop   │\n└─────────────────────────────────────────────┘\nUser can: ✏️ edit category · ☐ deselect row"]

  PREVIEW_UI --> USER_ACTION

  %% ── USER DECISION ────────────────────────────────────────────────────────
  USER_ACTION{{"👤 User action?"}}
  USER_ACTION -->|"Edit a category"| EDIT_CAT
  USER_ACTION -->|"Deselect a row"| DESELECT
  USER_ACTION -->|"Click Import"| CONFIRM

  EDIT_CAT["✏️ Category dropdown\nshows all user categories\nUser picks the right one"] --> PREVIEW_UI
  DESELECT["☐ Row unchecked\nWill be skipped\non import"] --> PREVIEW_UI

  %% ── CONFIRM IMPORT ───────────────────────────────────────────────────────
  CONFIRM["POST /api/v1/import/confirm\n{ rows: selected rows with\n  final category_ids }"]
  CONFIRM --> BULK_CREATE

  BULK_CREATE["⚡ Bulk create Expense records\nOne INSERT per selected row\nDuplicate detection:\n  skip rows with same date+amount+description\nReturns: { imported, skipped, errors }"]

  BULK_CREATE --> RESULT

  %% ── RESULT ───────────────────────────────────────────────────────────────
  RESULT{{"Import result?"}}
  RESULT -->|"All success"| SUCCESS
  RESULT -->|"Partial errors"| PARTIAL

  SUCCESS(["✅ Import Complete!\n84 expenses imported\nRedirecting to Expenses page…"])
  PARTIAL["⚠️ Import partial:\n79 imported · 5 skipped\n(duplicates detected)\nShow error details to user"]
  PARTIAL --> DONE(["✅ Done — user reviews\nany skipped rows"])

  %% ── STYLES ───────────────────────────────────────────────────────────────
  classDef userAction fill:#4F46E5,stroke:#3730A3,color:#fff
  classDef decision fill:#D97706,stroke:#B45309,color:#fff
  classDef parser fill:#059669,stroke:#047857,color:#fff
  classDef aiStep fill:#7C3AED,stroke:#6D28D9,color:#fff
  classDef ui fill:#0891B2,stroke:#0E7490,color:#fff
  classDef success fill:#16A34A,stroke:#15803D,color:#fff
  classDef error fill:#DC2626,stroke:#B91C1C,color:#fff
  classDef neutral fill:#6B7280,stroke:#4B5563,color:#fff

  class START,UPLOAD userAction
  class FILETYPE,DETECT,PDF_OK,USER_ACTION,RESULT decision
  class HDFC_S,HDFC_CC,SBI,ICICI,AXIS,GENERIC parser
  class AI_CAT,PREVIEW_BUILD aiStep
  class PREVIEW_UI,CSV_PARSE,PDF_EXTRACT,NORMALISE ui
  class SUCCESS,DONE success
  class PDF_ERR,PARTIAL error
  class CONFIRM,BULK_CREATE,EDIT_CAT,DESELECT neutral
